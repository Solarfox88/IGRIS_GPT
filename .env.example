# IGRIS_GPT Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Server
IGRIS_HOST=0.0.0.0
IGRIS_PORT=7778

# Project root — the directory IGRIS manages
PROJECT_ROOT=.
WORKSPACE_ROOT=.

# Local LLM (Ollama)
LOCAL_LLM_PROVIDER=ollama
LOCAL_LLM_MODEL=phi4-mini
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434

# Fallback LLM (OpenAI) — optional, used as fallback when DeepSeek is unavailable
FALLBACK_LLM_PROVIDER=openai
FALLBACK_LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# DeepSeek — primary execution provider (cheaper + better coding than gpt-4o-mini)
# V4-Flash: SWE-bench 79%, $0.14/$0.28 per 1M, 1M context, cache hit $0.0028/1M
# V4-Pro:   SWE-bench 80.6%, Codeforces ELO 3206, $0.435/$0.87 per 1M (75% off until May 2026)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash          # execution fallback economico
DEEPSEEK_STRONG_MODEL=deepseek-v4-pro     # execution strong/escalation

# VAST.ai — optional
VASTAI_API_KEY=
VASTAI_MODEL=deepseek-r1:32b
VASTAI_FALLBACK_MODEL=qwen2.5-coder:7b
VASTAI_AUTO_PROVISION=false
VASTAI_REQUIRE_APPROVAL=true
VASTAI_MAX_HOURLY_COST=0.50
VASTAI_MODE=on_demand
VAST_API_KEY=

# Safety
AUTO_COMMIT=false
AUTO_PUSH=false

# Execution Routing — controls which model the reasoning worker uses for code generation.
# Primary execution models are DeepSeek (above). OpenAI is the fallback when DeepSeek is unavailable.
# IGRIS_EXECUTION_ROUTING=auto               # auto | cloud_only (default: auto)
# IGRIS_EXECUTION_FALLBACK_MODEL=gpt-4o-mini # OpenAI fallback model (not the primary)
# IGRIS_EXECUTION_STRONG_MODEL=gpt-4o        # OpenAI strong fallback (behind deepseek-v4-pro)
# IGRIS_EXECUTION_PREFERRED_PROFILE=         # force a specific orchestrator profile per-run

# API Helper — supervisor escalation (optional, enabled per-run via allow_api_escalation=true)
# The command to invoke when the supervisor needs advisory help on a blocked run.
# The script reads a sanitized JSON packet from stdin and returns JSON advice to stdout.
# Output is advisory only — it never bypasses safety, tests, or CI.
IGRIS_API_HELPER_COMMAND="/home/igris/IGRIS_GPT/.venv/bin/python /home/igris/IGRIS_GPT/scripts/igris_api_helper.py"

# Mode: "codex_only" forces OpenAI/Codex exclusively (no Anthropic, no fallback defaults).
# "auto" (default) tries Anthropic first, then OpenAI.
IGRIS_API_HELPER_MODE=codex_only

# Provider override — "openai" or "anthropic". Required in codex_only mode: must be "openai".
IGRIS_API_HELPER_PROVIDER=openai

# Model — REQUIRED in codex_only mode. No default fallback (not gpt-4o-mini, not claude-haiku).
# Set to the exact Codex model name available on your OpenAI account.
# Example: IGRIS_API_HELPER_MODEL=codex-mini-latest
IGRIS_API_HELPER_MODEL=<CODEX_MODEL_NAME_HERE>

# API key for the helper (uses OPENAI_API_KEY above if not separately specified).
# IGRIS_OPENAI_API_KEY=   # optional override, falls back to OPENAI_API_KEY

# Timeout for each API call in seconds (default: 45).
# IGRIS_HELPER_TIMEOUT=45

# Helper A/B test — optional. Tests DeepSeek V4 Pro as an alternative advice helper.
# Do NOT enable in production until comparative success-rate data is available.
# When enabled, 50% of helper calls use IGRIS_API_HELPER_ALT_MODEL instead of IGRIS_API_HELPER_MODEL.
# Both models are still advice-only; neither executes code directly.
IGRIS_ENABLE_HELPER_AB_TEST=false
IGRIS_API_HELPER_ALT_MODEL=deepseek-v4-pro
# IGRIS_API_HELPER_ALT_PROVIDER=deepseek  # provider for alt model (default: deepseek)
# IGRIS_HELPER_AB_SPLIT=0.5               # fraction routed to alt (default: 0.5)
