# Docker-specific optional overrides (safe template, no secrets).
# Usage:
#   cp .env.docker.example .env.docker
#   docker compose --env-file .env.docker up --build

IGRIS_PORT=7778
PROJECT_ROOT=/workspace
WORKSPACE_ROOT=/workspace
AUTO_COMMIT=false
AUTO_PUSH=false

# Optional provider flags (keep keys empty unless you explicitly want cloud fallback).
LOCAL_LLM_PROVIDER=ollama
LOCAL_LLM_MODEL=phi4-mini
LOCAL_LLM_BASE_URL=http://host.docker.internal:11434
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
